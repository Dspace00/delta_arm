    <weld name="c6" body1="left_end_link3" body2="end_platform" solref="0.0001 0.99" solimp="0.99 0.999 0.0001" torquescale="1"/>
  </equality>

  <!-- 执行器 -->
  <actuator>
    <position name="armmotor1" joint="motor_arm_joint1" kp="100" kv="10" ctrllimited="true" ctrlrange="-1.57 0.523"/>
    <position name="armmotor2" joint="motor_arm_joint2" kp="100" kv="10" ctrllimited="true" ctrlrange="-1.57 0.523"/>
    <position name="armmotor3" joint="motor_arm_joint3" kp="100" kv="10" ctrllimited="true" ctrlrange="-1.57 0.523"/>
  </actuator>

  <!-- 传感器：末端位置/速度 + 小球位置/速度 -->
  <sensor>
    <!-- Delta末端相对于基座 -->
    <framepos name="ee_pos" objtype="site" objname="end_platform_center" reftype="site" refname="Delta_base_center"/>
    <framelinvel name="ee_lin_vel" objtype="site" objname="end_platform_center" reftype="site" refname="Delta_base_center"/>
    <!-- 小球位置和速度（世界坐标系） -->
    <framepos name="ball_pos" objtype="site" objname="ball_center"/>
    <framelinvel name="ball_lin_vel" objtype="site" objname="ball_center"/>
  </sensor>

  <visual>
    <global offwidth="1920" offheight="1680"/>
  </visual>

</mujoco>
